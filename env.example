import React, { useState, useEffect } from 'react';
import { Link, Outlet, useNavigate } from 'react-router-dom';
import { Search, Mail, User, ShoppingBag, MapPin, Youtube, Instagram, X, Plus, Minus, Trash2, LogOut, Menu } from 'lucide-react';
import { useCart } from '../context/CartContext';
import { STORE, formatPrice } from '../utils/auth';

export default function Layout() {
  const { totalItems, cart, removeFromCart, updateQuantity, totalPrice, isCartOpen, setIsCartOpen } = useCart();
  const navigate = useNavigate();
  const [user, setUser] = useState<any>(null);
  const [searchQuery, setSearchQuery] = useState('');
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);

  const handleSearch = (e: React.FormEvent) => {
    e.preventDefault();
    if (searchQuery.trim()) navigate(`/category/search?q=${encodeURIComponent(searchQuery.trim())}`);
  };

  useEffect(() => {
    const checkUser = () => {
      const saved = localStorage.getItem('app_user');
      setUser(saved ? JSON.parse(saved) : null);
    };
    checkUser();
    window.addEventListener('user-changed', checkUser);
    return () => window.removeEventListener('user-changed', checkUser);
  }, []);

  const navLinks = (
    <ul className="flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-8 text-[11px] font-bold tracking-widest uppercase whitespace-nowrap">
      <li><Link to="/" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Home</Link></li>
      <li className="relative group">
        <Link to="/category/products" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500 flex items-center gap-1">
          Product <svg className="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 9l-7 7-7-7"/></svg>
        </Link>
        <div className="absolute left-0 top-full w-56 bg-white border border-gray-200 shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div className="absolute -top-2 left-0 w-full h-2 bg-transparent" />
          <ul className="py-2">
            {[['cleansing','Cleansing'],['toner-mist','Toner & Mist'],['cream','Cream'],['special-treatment','Special Treatment'],['mask','Mask'],['sun-protection','Sun Protection'],['professional-spa-line','Professional Spa Line'],['beauty-tools','Beauty Tools'],['gift','Gift']].map(([slug,label]) => (
              <li key={slug}><Link to={`/category/${slug}`} onClick={() => setIsMobileMenuOpen(false)} className="block px-4 py-2 hover:bg-gray-100 normal-case font-normal">{label}</Link></li>
            ))}
          </ul>
        </div>
      </li>
      <li><Link to="/skin-science" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Skin Science</Link></li>
      <li><Link to="/spa-solution" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Spa Solution</Link></li>
      <li><Link to="/news" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">News</Link></li>
      <li><Link to="/policies" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Policies</Link></li>
      <li><Link to="/contact" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Contact</Link></li>
      <li><Link to="/discovery" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">Discovery</Link></li>
      <li><Link to="/about" onClick={() => setIsMobileMenuOpen(false)} className="hover:text-gray-500">About Us</Link></li>
    </ul>
  );

  return (
    <div className="min-h-screen flex flex-col font-sans text-[#1a1a1a] bg-[#f4f4f4]">
      {/* Mobile Menu */}
      <div className={`fixed inset-0 z-[110] bg-white p-6 md:hidden transition-transform duration-300 ${isMobileMenuOpen?'translate-x-0':'translate-x-full'}`}>
        <div className="flex justify-end mb-8"><button onClick={() => setIsMobileMenuOpen(false)}><X size={24} /></button></div>
        {navLinks}
      </div>

      {/* Cart Drawer */}
      <div className={`fixed inset-0 z-[100] transition-opacity duration-300 ${isCartOpen?'opacity-100 pointer-events-auto':'opacity-0 pointer-events-none'}`}>
        <div className="absolute inset-0 bg-black/40 backdrop-blur-sm" onClick={() => setIsCartOpen(false)} />
        <div className={`absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl transition-transform duration-500 transform ${isCartOpen?'translate-x-0':'translate-x-full'}`}>
          <div className="flex flex-col h-full">
            <div className="p-6 border-b border-gray-100 flex items-center justify-between">
              <h2 className="text-sm font-bold uppercase tracking-[0.2em]">Giỏ hàng của bạn ({totalItems})</h2>
              <button onClick={() => setIsCartOpen(false)} className="p-2 hover:bg-gray-100 rounded-full"><X size={20} /></button>
            </div>
            <div className="flex-grow overflow-y-auto p-6 space-y-6">
              {cart.length === 0 ? (
                <div className="h-full flex flex-col items-center justify-center text-center space-y-4">
                  <ShoppingBag size={48} className="text-gray-200" />
                  <p className="text-xs uppercase tracking-widest text-gray-400">Giỏ hàng đang trống</p>
                  <button onClick={() => setIsCartOpen(false)} className="text-[11px] font-bold uppercase tracking-widest underline underline-offset-4">Tiếp tục mua sắm</button>
                </div>
              ) : cart.map((item) => (
                <div key={item.id} className="flex gap-4 group">
                  <div className="w-24 h-24 bg-gray-50 rounded-lg overflow-hidden flex-shrink-0"><img src={item.image} alt={item.name} className="w-full h-full object-cover" /></div>
                  <div className="flex-grow flex flex-col justify-between py-1">
                    <div>
                      <div className="flex justify-between items-start">
                        <h3 className="text-[13px] font-bold uppercase tracking-wider">{item.name}</h3>
                        <button onClick={() => removeFromCart(item.id)} className="text-gray-400 hover:text-red-500"><Trash2 size={14} /></button>
                      </div>
                      <p className="text-[11px] text-gray-400 uppercase tracking-widest mt-1">{item.size} / {item.scent}</p>
                    </div>
                    <div className="flex justify-between items-center">
                      <div className="flex items-center border border-gray-200 rounded-lg overflow-hidden">
                        <button onClick={() => updateQuantity(item.id, item.quantity-1)} className="p-1.5 hover:bg-gray-50 border-r border-gray-200"><Minus size={12} /></button>
                        <span className="px-3 text-xs font-mono">{item.quantity}</span>
                        <button onClick={() => updateQuantity(item.id, item.quantity+1)} className="p-1.5 hover:bg-gray-50 border-l border-gray-200"><Plus size={12} /></button>
                      </div>
                      <span className="text-xs font-bold">{item.price}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            {cart.length > 0 && (
              <div className="p-6 border-t border-gray-100 bg-gray-50/50 space-y-4">
                <div className="flex justify-between items-center">
                  <span className="text-[11px] font-bold uppercase tracking-widest text-gray-400">Tổng cộng</span>
                  <span className="text-lg font-bold">{totalPrice.toLocaleString()}đ</span>
                </div>
                <button onClick={() => { setIsCartOpen(false); navigate('/checkout'); }} className="w-full bg-black text-white py-4 rounded-xl text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-gray-800 transition-all shadow-lg shadow-black/10">
                  Thanh toán ngay
                </button>
                <p className="text-[9px] text-center text-gray-400 uppercase tracking-widest">Miễn phí vận chuyển cho đơn hàng trên 2.500.000đ</p>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Top Banner */}
      <div className="bg-[#5a5a5a] text-white text-center py-2 text-[11px] tracking-widest">
        <p>Miễn phí vận chuyển tiêu chuẩn cho đơn hàng trên 2.500.000đ (<Link to="/policies" className="underline hover:text-gray-300">xem thêm</Link>).</p>
      </div>

      {/* Header */}
      <header className="px-6 py-4 flex flex-col md:flex-row items-center justify-between border-b border-gray-200 bg-[#f4f4f4]">
        <div className="w-full md:w-1/4 flex justify-between items-center mb-4 md:mb-0">
          <Link to="/" className="text-3xl font-bold tracking-[0.1em] uppercase leading-none">
            {STORE.name}
            <span className="block text-[9px] font-normal tracking-[0.2em] mt-1">{STORE.tagline}</span>
          </Link>
          <button className="md:hidden" onClick={() => setIsMobileMenuOpen(true)}><Menu className="w-6 h-6 stroke-1" /></button>
        </div>
        <div className="w-full md:w-2/4 flex justify-center mb-4 md:mb-0">
          <form onSubmit={handleSearch} className="relative w-full max-w-2xl flex items-center border-b border-gray-300 pb-1">
            <button type="submit" className="focus:outline-none"><Search className="w-4 h-4 text-gray-400 mr-2 hover:text-black transition-colors" /></button>
            <input type="text" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} placeholder="Tìm kiếm sản phẩm..." className="w-full text-xs font-mono bg-transparent focus:outline-none placeholder-gray-400" />
          </form>
        </div>
        <div className="w-full md:w-1/4 flex items-center justify-end space-x-6">
          <a href={`mailto:${STORE.email}`} className="hover:text-gray-600"><Mail className="w-5 h-5 stroke-1" /></a>
          {user ? (
            <div className="flex items-center gap-4">
              <Link to="/auth" className="flex items-center gap-2 hover:text-gray-600">
                <div className="w-8 h-8 bg-black text-white rounded-full flex items-center justify-center text-[10px] font-bold">
                  {(user.firstName?.[0]||'').toUpperCase()}{(user.lastName?.[0]||'').toUpperCase()}
                </div>
                <span className="text-[10px] font-bold uppercase tracking-widest hidden lg:block">{user.firstName}</span>
              </Link>
              <button onClick={() => { localStorage.removeItem('app_user'); window.dispatchEvent(new Event('user-changed')); }} className="hover:text-red-500 transition-colors" title="Đăng xuất"><LogOut className="w-4 h-4 stroke-1" /></button>
            </div>
          ) : (
            <Link to="/auth" className="hover:text-gray-600"><User className="w-5 h-5 stroke-1" /></Link>
          )}
          <button onClick={() => setIsCartOpen(true)} className="hover:text-gray-600 flex items-center gap-2 relative">
            <ShoppingBag className="w-5 h-5 stroke-1" />
            <span className="text-xs font-mono">({totalItems})</span>
            {totalItems > 0 && <span className="absolute -top-1 -right-1 w-2 h-2 bg-black rounded-full animate-pulse" />}
          </button>
        </div>
      </header>

      <nav className="hidden md:block px-6 py-4 border-b border-gray-200 bg-[#f4f4f4] relative z-40">{navLinks}</nav>

      <main className="flex-grow"><Outlet /></main>

      <footer className="bg-[#f4f4f4] pt-16 pb-8 px-6 border-t border-gray-200 mt-12">
        <div className="max-w-[1400px] mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-8 mb-16">
          <div><h3 className="text-[11px] font-normal text-gray-800 mb-4">Về {STORE.name}</h3>
            <ul className="space-y-2 text-[11px] text-gray-500">
              {[['about','Về chúng tôi'],['discovery','Khám phá'],['news','Tin tức'],['contact','Liên hệ']].map(([path,label]) => (
                <li key={path}><Link to={`/${path}`} className="hover:text-black">{label}</Link></li>
              ))}
            </ul>
          </div>
          <div><h3 className="text-[11px] font-normal text-gray-800 mb-4">Chăm sóc khách hàng</h3>
            <ul className="space-y-2 text-[11px] text-gray-500">
              {[['contact','Liên hệ với chúng tôi'],['auth','Trạng thái đơn hàng'],['policies','Vận chuyển & Đổi trả'],['policies','Câu hỏi thường gặp']].map(([path,label],i) => (
                <li key={i}><Link to={`/${path}`} className="hover:text-black">{label}</Link></li>
              ))}
            </ul>
          </div>
          <div><h3 className="text-[11px] font-normal text-gray-800 mb-4">Quyền riêng tư & Điều khoản</h3>
            <ul className="space-y-2 text-[11px] text-gray-500">
              {['Chính sách bảo mật','Điều khoản & Điều kiện'].map(label => (
                <li key={label}><Link to="/policies" className="hover:text-black">{label}</Link></li>
              ))}
            </ul>
          </div>
          <div><h3 className="text-[11px] font-normal text-gray-800 mb-4">Ghé thăm chúng tôi</h3>
            <ul className="space-y-2 text-[11px] text-gray-500">
              <li className="text-gray-500">{STORE.address}</li>
              <li><a href={`tel:${STORE.phone}`} className="hover:text-black">{STORE.phone}</a></li>
              <li><a href={`mailto:${STORE.email}`} className="hover:text-black">{STORE.email}</a></li>
            </ul>
          </div>
          <div><h3 className="text-[11px] font-normal text-gray-800 mb-4">Đăng ký nhận bản tin</h3>
            <p className="text-[10px] text-gray-400 leading-relaxed mb-4">Nhận thông tin về sản phẩm mới và ưu đãi độc quyền.</p>
            <form className="flex flex-col space-y-4" onSubmit={(e) => { e.preventDefault(); alert('Đăng ký thành công!'); }}>
              <input type="email" placeholder="Nhập địa chỉ email" required className="border border-gray-200 bg-white py-3 px-4 focus:outline-none focus:border-black text-xs font-mono" />
              <button type="submit" className="text-left text-[11px] font-normal underline hover:text-gray-600">Đăng ký</button>
            </form>
          </div>
        </div>
        <div className="max-w-[1400px] mx-auto flex flex-col md:flex-row items-center justify-between pt-8 border-t border-gray-200 text-[11px] text-gray-500">
          <div className="flex items-center space-x-2 mb-4 md:mb-0"><MapPin className="w-3 h-3" /><span>Việt Nam</span></div>
          <div className="flex items-center space-x-4">
            <span className="text-[10px] text-gray-400">© 2024 {STORE.name}. All rights reserved.</span>
            <a href="#" className="hover:text-black"><Youtube className="w-4 h-4" /></a>
            <a href="#" className="hover:text-black"><Instagram className="w-4 h-4" /></a>
          </div>
        </div>
      </footer>
    </div>
  );
}
